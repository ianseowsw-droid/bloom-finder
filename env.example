VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Only needed for the native (Capacitor) build. The native app has no server
# of its own, so it calls the deployed web app's API routes over the network.
# Set this to your published Lovable URL (or custom domain) before running
# `bun run build:mobile`. Leave unset for the web build — it uses same-origin
# relative requests instead.
VITE_API_BASE_URL=https://your-published-project.lovable.app
